{
  "name": "n8n-nodes-tradingview",
  "version": "0.1.0",
  "description": "n8n community nodes for TradingView: REST operations and webhook trigger",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "n8n-community-node",
    "n8n-nodes",
    "tradingview",
    "webhook",
    "rest"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && npm run copy:assets",
    "copy:assets": "mkdir -p dist/nodes/TradingView dist/nodes/TradingViewTrigger && cp src/nodes/TradingView/tradingview.svg dist/nodes/TradingView/tradingview.svg && cp src/nodes/TradingView/tradingview.svg dist/nodes/TradingViewTrigger/tradingview.svg",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepare": "tsc && npm run copy:assets"
  },
  "dependencies": {
    "axios": "^1.7.7"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "n8n-workflow": "^1.42.0",
    "typescript": "^5.5.4"
  },
  "n8n": {
    "credentials": [
      "dist/credentials/TradingViewApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/TradingView/TradingView.node.js",
      "dist/nodes/TradingViewTrigger/TradingViewTrigger.node.js"
    ]
  }
}


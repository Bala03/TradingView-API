{
  "name": "@mathieuc/tradingview",
  "version": "3.5.1",
  "description": "Tradingview instant stocks API, indicator alerts, trading bot, and more !",
  "main": "main.js",
  "scripts": {
    "test": "vitest",
    "test:unit": "vitest run tests/helpers.test.ts tests/utils.test.ts --reporter=verbose",
    "test:ci": "vitest run --reporter=verbose",
    "lint": "eslint ./src --fix",
    "lint:check": "eslint ./src",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "example": "node --env-file=.env examples/StreamlinedExample.js",
    "example:dev": "nodemon --env-file=.env examples/StreamlinedExample.js",
    "example:simple": "node --env-file=.env examples/SimpleChart.js",
    "example:login": "node --env-file=.env examples/UserLogin.js",
    "example:all": "node --env-file=.env examples/StreamlinedExample.js && node --env-file=.env examples/SimpleChart.js",
    "config:test": "node -e \"console.log(require('./src/config').all)\"",
    "session:test": "node -e \"require('./src/sessionManager').getSession().then(console.log).catch(console.error)\"",
    "setup": "cp .env.example .env && echo 'Please edit .env file with your TradingView credentials'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mathieu2301/TradingView-API.git"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "keywords": [
    "tradingwiew",
    "market",
    "stocks",
    "crypto",
    "forex",
    "indicator",
    "bitcoin",
    "api"
  ],
  "author": "Mathieu Colmon",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.12.2",
    "jszip": "^3.10.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.4",
    "@mathieuc/console": "^1.0.1",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^14.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "vitest": "^3.2.4"
  }
}

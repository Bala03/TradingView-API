# TradingView API Configuration
# Copy this file to .env and fill in your actual values

# TradingView Authentication
TRADINGVIEW_USERNAME=your_username_or_email
TRADINGVIEW_PASSWORD=your_password

# Session Management (optional - will be auto-generated if not provided)
TRADINGVIEW_SESSION_ID=your_session_id
TRADINGVIEW_SIGNATURE=your_signature

# API Configuration
TRADINGVIEW_USER_AGENT=TWAPI/3.0
TRADINGVIEW_REMEMBER_SESSION=true

# Default Market Settings
DEFAULT_MARKET=BINANCE:BTCEUR
DEFAULT_TIMEFRAME=D
DEFAULT_CHART_TYPE=HeikinAshi

# Connection Settings
WEBSOCKET_TIMEOUT=30000
REQUEST_TIMEOUT=10000
MAX_RETRIES=3

# Logging
LOG_LEVEL=info
ENABLE_DEBUG=false